# Copia este archivo a content_agent/.env y rellena los valores.
# ADK lo carga automáticamente al correr `adk web` / `adk run`.

# --- Vertex AI (LLM) ---
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=tu-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Ruta a tu service account JSON (las credenciales de Vertex que ya tienes)
GOOGLE_APPLICATION_CREDENTIALS=service_account.json

# Modelo (sobre Vertex). Cambia a gemini-2.5-pro si quieres más razonamiento.
AGENT_MODEL=gemini-2.5-flash

# --- Gmail (human-in-the-loop) ---
# OAuth client tipo Desktop descargado de Google Cloud Console.
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json
# A quién se le manda el correo de revisión (default: tu propia cuenta).
# GMAIL_REVIEWER=tu-correo@gmail.com

# --- Tendencias (contrato con tvesah) ---
TRENDS_PATH=trends_input/trends.json
