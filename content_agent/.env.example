# Copy this file to content_agent/.env and fill in the values.
# ADK loads it automatically when running `adk web` / `adk run`.

# --- Vertex AI (LLM) ---
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Path to your service account JSON (the Vertex credentials you already have)
GOOGLE_APPLICATION_CREDENTIALS=service_account.json

# Model (on Vertex). Switch to gemini-2.5-pro if you want more reasoning.
AGENT_MODEL=gemini-2.5-flash

# --- Gmail (human-in-the-loop) ---
# Option A (preferred, headless): Desktop OAuth client credentials + refresh token.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# Option B (fallback): Desktop OAuth client downloaded from Google Cloud Console.
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json
# Who the review email is sent to (default: your own account).
# GMAIL_REVIEWER=your-email@gmail.com

# --- Trends ---
# Real trends come from the dashboard (data/dashboard-db.json). This static file
# is only a fallback used before the dashboard has pulled live Polymarket data.
TRENDS_PATH=trends_input/trends.json
